# tm init creates the ledger branch and prints next steps.
exec tm init
stdout 'Initialized TeamMemory ledger on branch "teammemory"'
stdout 'mcpServers'

# Re-running is idempotent and reports the existing ledger.
exec tm init
stdout 'already initialized'

# The orphan branch exists with a policy.yaml.
exec git cat-file -p teammemory:policy.yaml
stdout 'base_risk'
